
! Last configuration change at 20:06:03 UTC Fri May 29 2026
!
version 15.9
service timestamps debug datetime msec
service timestamps log datetime msec
no service password-encryption
!
hostname spine-1
!
!
interface Loopback0
 ip address 172.16.0.1 255.255.255.255
!
interface GigabitEthernet0/0
 description iosv-0 gi0/0 <--> nxos9000-0 e1/1
 ip address 39.0.0.1 255.255.255.252
 duplex auto
 speed auto
 media-type rj45
!
interface GigabitEthernet0/1
 description iosv-0 <--> nxos9000-1 e1/2
 ip address 40.0.0.1 255.255.255.252
 duplex auto
 speed auto
 media-type rj45
!
interface GigabitEthernet0/2
 no ip address
 shutdown
 duplex auto
 speed auto
 media-type rj45
!
interface GigabitEthernet0/3
 no ip address
 shutdown
 duplex auto
 speed auto
 media-type rj45
!
router bgp 65000
 bgp router-id 172.16.0.1
 bgp log-neighbor-changes
 neighbor 172.16.0.2 remote-as 65000
 neighbor 172.17.0.2 remote-as 65000
 !
 address-family l2vpn evpn
  neighbor 172.16.0.2 activate
  neighbor 172.16.0.2 send-community both
  neighbor 172.16.0.2 route-reflector-client
  neighbor 172.17.0.2 activate
  neighbor 172.17.0.2 send-community both
  neighbor 172.17.0.2 route-reflector-client
 exit-address-family
!
ip forward-protocol nd
!
!
no ip http server
no ip http secure-server
! Static routes for loopback connectivity..
!
ip route 10.0.11.1 255.255.255.255 39.0.0.2
ip route 10.0.12.1 255.255.255.255 40.0.0.2
ip route 172.16.0.2 255.255.255.255 39.0.0.2
ip route 172.17.0.2 255.255.255.255 40.0.0.2
!
ipv6 ioam timestamp
!
!
!
control-plane
!

line con 0
line aux 0
line vty 0 4
 login
 transport input none
!
no scheduler allocate
!
end

