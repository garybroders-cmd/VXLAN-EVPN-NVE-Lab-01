
hostname leaf-a
!
! Add features replicated on both Leafs
!
nv overlay evpn
feature bgp
feature fabric forwarding
feature interface-vlan
feature vn-segment-vlan-based
feature nv overlay
!
no password strength-check
!
username admin password Cisco123
!
ip domain-lookup
!
hardware access-list tcam region racl 512
hardware access-list tcam region arp-ether 256 double-wide
!
!
!
fabric forwarding anycast-gateway-mac 0001.0001.0001
!
! static routes back to spine-1 only
!
ip route 172.16.0.1/32 39.0.0.1
ip route 172.17.0.2/32 39.0.0.1
!
!
vlan 1,10,20,50
vlan 10
  name VLAN00010
  vn-segment 1010
vlan 20
  name VLAN00020
  vn-segment 10020
vlan 50
  name VLAN00050
  vn-segment 50000
!
!
route-map RM-REDIST-DIRECT permit 10
exit
!
vrf context PROD
  vni 50000
  rd 172.16.0.2:50000
  address-family ipv4 unicast
    route-target import 65000:50000
    route-target export 65000:50000
!
vrf context management
!
interface Vlan1
!
interface Vlan10
  no shutdown
  vrf member PROD
  ip address 192.168.10.1/24
  fabric forwarding mode anycast-gateway
!
interface Vlan20
  no shutdown
  vrf member PROD
  ip address 192.168.20.1/24
  fabric forwarding mode anycast-gateway
!
interface Vlan50
  no shutdown
  vrf member PROD
  ip forward
!
interface nve1
  no shutdown
  host-reachability protocol bgp
  source-interface loopback0 
  member vni 1010
    ingress-replication protocol bgp
  member vni 10020
    ingress-replication protocol bgp
  member vni 50000 associate-vrf
!
interface Ethernet1/1
  description e1/1 <--> spine-1 gi1/0
  no switchport
  ip address 39.0.0.2/30
  no shutdown
  exit
!
interface Ethernet1/2
  description e1/2 <--> ispine2 gi0/2
  no switchport
  ip address 60.0.0.2/30
  no shutdown
  exit
!
interface Ethernet1/10
  switchport
  switchport access vlan 10
  no shutdown
interface Ethernet1/11
  switchport
  switchport access vlan 10
  no shutdown
  exit
!
interface Ethernet1/15
  switchport access vlan 20
  no shutdown
interface Ethernet1/16
  switchport access vlan 20
  no shutdown
  exit
!
interface mgmt0
  vrf member management
!
interface loopback0
  description used for nve peer and bgp 
! loopback used for nve peers and bgp 
  ip address 172.16.0.2/32
  exit
!
!
icam monitor scale
icam monitor system
!
! taken from dir bootflash: add this in so Nexus boots up that image.
! look at version in dir bootflash:
!
boot nxos bootflash:/nxos64-cs.10.5.1.F.bin
!
router bgp 65000
  router-id 172.16.0.2
  bestpath as-path multipath-relax
  address-family ipv4 unicast
  address-family l2vpn evpn
    retain route-target all
  neighbor 172.16.0.1
    remote-as 65000
    log-neighbor-changes
    update-source loopback0
    address-family l2vpn evpn
      send-community
      send-community extended
  vrf PROD
    address-family ipv4 unicast
      redistribute direct route-map RM-REDIST-DIRECT
      exit
!
end
